{%- set all_versions = ["3.10", "3.11", "3.12", "3.13", "3.14"] -%}
{%- set min_minor = python_version_minimum.split(".")[1] | int -%}
{%- macro for_each_version() -%}
{%- for v in all_versions if v.split(".")[1] | int >= min_minor -%}
{{ caller(loop, v) }}
{%- endfor -%}
{%- endmacro -%}

{%- macro latest() -%}
{{- all_versions|last -}}
{%- endmacro -%}
