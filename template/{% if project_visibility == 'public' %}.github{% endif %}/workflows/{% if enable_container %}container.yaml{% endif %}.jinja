name: Container

on:
  pull_request:
  push:
    branches: [main]
    tags:
      - v[0-9]*.[0-9]*

jobs:
  build-push:
    name: Build and push image
    runs-on: ubuntu-latest
    permissions:
      packages: write
      contents: read
      attestations: write
      id-token: write
    steps:
      - name: 💾 Check out repository
        uses: actions/checkout@v6

      - name: 🛠️ Set up buildx
        uses: docker/setup-buildx-action@v3

      - name: 🔑 Log in to the container registry
        uses: docker/login-action@v3
        if: {% raw %}${{ github.event_name != 'pull_request' }}{% endraw %}
        with:
          registry: ghcr.io
          username: {% raw %}${{ github.actor }}{% endraw %}
          password: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}

      - name: 📡 Collect image metadata
        uses: docker/metadata-action@v5
        id: meta
        with:
          images: {% raw %}ghcr.io/${{ github.repository }}{% endraw %}
          tags: |
            type=ref,event=branch
            {% raw %}type=semver,pattern={{version}}
            type=semver,pattern={{major}}.{{minor}}
            type=semver,pattern={{major}}{% endraw %}
            type=sha

      - name: 📦 Build and publish container image
        uses: docker/build-push-action@v6
        id: push
        with:
          context: .
          push: {% raw %}${{ github.event_name != 'pull_request' }}{% endraw %}
          platforms: linux/amd64,linux/arm64
          tags: {% raw %}${{ steps.meta.outputs.tags }}{% endraw %}
          labels: {% raw %}${{ steps.meta.outputs.labels }}{% endraw %}
          cache-from: type=gha
          cache-to: type=gha,mode=max

      - name: 🔒 Attest build provenance
        uses: actions/attest-build-provenance@v2
        if: {% raw %}${{ github.event_name != 'pull_request' }}{% endraw %}
        with:
          subject-name: {% raw %}ghcr.io/${{ github.repository }}{% endraw %}
          subject-digest: {% raw %}${{ steps.push.outputs.digest }}{% endraw %}
{#- vim: set ft=yaml: #}
