{%- import "includes/python.jinja" as py with context -%}
name: Release

on:
  push:
    tags:
      - '[0-9]*.[0-9]*'

jobs:
  build:
    name: Build distribution
    runs-on: ubuntu-latest
    steps:
      - name: 💾 Check out repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: 🦀 Set up Python project with uv
        uses: astral-sh/setup-uv@v5
        with:
          enable-cache: true
          python-version: '{{ py.latest() }}'

      - name: 📦 Build package
        run: uv build

      - name: 🔼 Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: dist
          path: dist/

  publish:
    name: Publish to PyPI
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: pypi
      url: https://pypi.org/project/{{ project_name }}/
    permissions:
      id-token: write
      attestations: write
    steps:
      - name: 🔽 Download artifact
        uses: actions/download-artifact@v4
        with:
          name: dist
          path: dist/

      - name: ☢️ Publish to PyPI
        uses: pypa/gh-action-pypi-publish@release/v1
        with:
          attestations: true

  release:
    name: Create GitHub release
    needs: publish
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - name: 🔽 Download artifact
        uses: actions/download-artifact@v4
        with:
          name: dist
          path: dist/

      - name: 🏷️ Create GitHub release
        run: gh release create {% raw %}${{ github.ref_name }}{% endraw %} dist/* --generate-notes
        env:
          GH_TOKEN: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}
{#- vim: set ft=yaml: #}
